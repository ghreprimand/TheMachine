# ═══════════════════════════════════════════════════════════════════════════════
# machine-dump.hex — x86_64 machine code, byte by byte
#
# Build:
#   sed 's/#.*//' machine-dump.hex | tr -d ' \n\r' | xxd -r -p > machine-dump
#   chmod +x machine-dump
#
# rbp = BSS base (survives syscalls). syscall clobbers rax, rcx, r11.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── ELF HEADER (64 bytes) ───────────────────────────────────────────────────
7f 45 4c 46 02 01 01 00          # ELF magic, 64-bit, LE, v1, SysV
00 00 00 00 00 00 00 00          # padding
02 00 3e 00 01 00 00 00          # ET_EXEC, x86_64, version 1
78 00 40 00 00 00 00 00          # entry: 0x400078
40 00 00 00 00 00 00 00          # phdr at 64
00 00 00 00 00 00 00 00          # no section headers
00 00 00 00 40 00 38 00          # flags, ehsize=64, phentsize=56
01 00 00 00 00 00 00 00          # 1 phdr, no shdr

# ─── PROGRAM HEADER (56 bytes) ───────────────────────────────────────────────
01 00 00 00 07 00 00 00          # PT_LOAD, RWX
00 00 00 00 00 00 00 00          # offset: 0
00 00 40 00 00 00 00 00          # vaddr: 0x400000
00 00 40 00 00 00 00 00          # paddr: 0x400000
f5 0e 00 00 00 00 00 00          # filesz: 3829
3d 11 02 00 00 00 00 00          # memsz: 135485 (131656 BSS = 128KB output buffer)
00 00 20 00 00 00 00 00          # align: 0x200000

